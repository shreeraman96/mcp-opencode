{
  "name": "mcp-coding-agents-workspace",
  "private": true,
  "description": "Workspace for the independent mcp-opencode and mcp-grok MCP servers.",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm test --workspaces --if-present",
    "smoke": "npm run smoke --workspace mcp-opencode",
    "pack:opencode": "npm pack --workspace mcp-opencode --dry-run",
    "pack:grok": "npm pack --workspace mcp-grok --dry-run"
  }
}
