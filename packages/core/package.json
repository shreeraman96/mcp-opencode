{
  "name": "@mcp-coding-agents/core",
  "version": "0.1.0",
  "private": true,
  "description": "Internal shared runtime for mcp-opencode / mcp-grok (and the future mcp-router): run/parse/classify/redact/validateCwd. Never published; bundled into each product's dist at build.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./text.js": {
      "types": "./dist/text.d.ts",
      "default": "./dist/text.js"
    },
    "./cwd.js": {
      "types": "./dist/cwd.d.ts",
      "default": "./dist/cwd.js"
    },
    "./queue.js": {
      "types": "./dist/queue.d.ts",
      "default": "./dist/queue.js"
    },
    "./errors.js": {
      "types": "./dist/errors.d.ts",
      "default": "./dist/errors.js"
    },
    "./types.js": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./backends/opencode.js": {
      "types": "./dist/backends/opencode.d.ts",
      "default": "./dist/backends/opencode.js"
    },
    "./backends/grok.js": {
      "types": "./dist/backends/grok.d.ts",
      "default": "./dist/backends/grok.js"
    },
    "./backends/codex.js": {
      "types": "./dist/backends/codex.d.ts",
      "default": "./dist/backends/codex.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^5.6.2",
    "vitest": "^2.1.4",
    "@types/node": "^20.14.0"
  }
}
